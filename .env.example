# Production Environment Configuration
# Copy this to .env.production for production deployment

# API Configuration - Update these for your production server
VITE_API_BASE_URL=https://your-production-api.com/api
VITE_BACKEND_URL=https://your-production-api.com

# Environment
VITE_NODE_ENV=production

# File Upload Configuration
VITE_MAX_FILE_SIZE=5242880
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png,image/gif,image/webp

# Application Configuration
VITE_APP_NAME=Project Management System
VITE_APP_VERSION=1.0.0

# Default Images - Consider using your own CDN URLs
VITE_DEFAULT_AVATAR_URL=https://your-cdn.com/default-avatar.png
VITE_DEFAULT_PROJECT_URL=https://your-cdn.com/default-project.png
VITE_DEFAULT_PLACEHOLDER_URL=https://your-cdn.com/placeholder.png

# Authentication
VITE_TOKEN_STORAGE_KEY=authToken
VITE_TOKEN_EXPIRES_HOURS=24

# Debug Mode - Disabled in production
VITE_DEBUG_MODE=false
VITE_ENABLE_CONSOLE_LOGS=false
